# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control

# Amazon affiliate tag used in generated amazon.com.br links
AMAZON_AFFILIATE_TAG=your-amazon-tag-here

# Mercado Livre affiliate data
# Login is currently manual via browser, but these fields are kept for future use/reference
ML_AFFILIATE_EMAIL=your-email@example.com
ML_AFFILIATE_PASSWORD=your-password-here

# Optional proxy, only if you want/need to route ML affiliate access through one
ML_PROXY=http://your-proxy-here:port

# WhatsApp configuration
# Used as the default group for scan_deals.py and send_to_whatsapp.py
WHATSAPP_GROUP=your-whatsapp-group-name-here
